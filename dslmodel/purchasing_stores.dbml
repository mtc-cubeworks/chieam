  entity PurchaseOrder {
    label = "Purchase Order";
    category = transactional;
    kind = root;

    field id : string { required = true; }
    field workflow_state : string { label = "Workflow State"; }
    field order_date : date { label = "Order Date"; }
    field delivery_date : date { label = "Delivery Date"; }
    field vendor : string { label = "Vendor"; }
    field site : string { label = "Site"; }
    field store : string { label = "Store"; }
    field currency : string { label = "Currency"; }
    field exchange_rate : decimal { label = "Exchange Rate"; }
    field subtotal : decimal { label = "Subtotal"; }
    field tax_amount : decimal { label = "Tax Amount"; }
    field total_amount : decimal { label = "Total Amount"; }
    field purchase_request : string { label = "Purchase Request"; }
    field rfq : string { label = "RFQ"; }
    field payment_terms : string { label = "Payment Terms"; }
    field shipping_method : string { label = "Shipping Method"; }
    field notes : text { label = "Notes"; }

    relation vendor-ref {
      from = purchasing_stores.PurchaseOrder.vendor;
      to = purchasing_stores.Vendor.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation site-ref {
      from = purchasing_stores.PurchaseOrder.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation store-ref {
      from = purchasing_stores.PurchaseOrder.store;
      to = purchasing_stores.Store.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation currency-ref {
      from = purchasing_stores.PurchaseOrder.currency;
      to = purchasing_stores.Currency.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation pr-ref {
      from = purchasing_stores.PurchaseOrder.purchase_request;
      to = purchasing_stores.PurchaseRequest.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation rfq-ref {
      from = purchasing_stores.PurchaseOrder.rfq;
      to = purchasing_stores.RequestForQuotation.id;
      kind = association;
      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.purchase-order-lifecycle;

    behavior {
      workflow use purchasing_stores.purchase-order-workflow;

      on send {
        do = purchasing_stores.send-po-to-vendor;
      }

      permissions {
        role core.admin {
          allow = read, write, create, delete;
        }
        role core.manager {
          allow = read, write, create, submit, approve;
        }
        role core.storekeeper {
          allow = read, write, create, submit;
        }
        role core.viewer {
          allow = read;
        }
      }
    }
  }

