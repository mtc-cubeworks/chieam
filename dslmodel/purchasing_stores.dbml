  (* ENTITIES — TRANSFER                        *)
  (* ========================================== *)

  entity Transfer {
    label = "Store Transfer";
    category = transactional;
    kind = root;

    field id : string { required = true; }
    field workflow_state : string { label = "Workflow State"; }
    field transfer_date : date { label = "Transfer Date"; }
    field from_store : string { label = "From Store"; }
    field to_store : string { label = "To Store"; }
    field site : string { label = "Site"; }
    field requested_by : string { label = "Requested By"; }
    field notes : text { label = "Notes"; }

    relation from-store-ref {
      from = purchasing_stores.Transfer.from_store;
      to = purchasing_stores.Store.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation to-store-ref {
      from = purchasing_stores.Transfer.to_store;
      to = purchasing_stores.Store.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation site-ref {
      from = purchasing_stores.Transfer.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation requested-ref {
      from = purchasing_stores.Transfer.requested_by;
      to = core.Employee.id;
      kind = association;
      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.transfer-lifecycle;

    behavior {
      workflow use purchasing_stores.transfer-workflow;
    }
  }

  entity TransferReceipt {
    label = "Transfer Receipt";
    category = transactional;
    kind = child;

    field id : string { required = true; }
    field transfer : string { label = "Transfer"; }
    field item : string { label = "Item"; }
    field quantity : integer { label = "Quantity"; }
    field from_bin : string { label = "From Bin"; }
    field to_bin : string { label = "To Bin"; }
    field received_date : date { label = "Received Date"; }

    relation transfer-ref {
      from = purchasing_stores.TransferReceipt.transfer;
      to = purchasing_stores.Transfer.id;
      kind = composition;
      cardinality = many-to-one;
    }

    relation item-ref {
      from = purchasing_stores.TransferReceipt.item;
      to = purchasing_stores.Item.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation from-bin-ref {
      from = purchasing_stores.TransferReceipt.from_bin;
      to = purchasing_stores.Bin.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation to-bin-ref {
      from = purchasing_stores.TransferReceipt.to_bin;
      to = purchasing_stores.Bin.id;
      kind = association;
      cardinality = many-to-one;
    }
  }

  (* ========================================== *)
  (* ENTITIES — VENDOR INVOICE & CONTRACTS      *)
  (* ========================================== *)

  entity ServiceContract {
    label = "Service Contract";
    category = transactional;
    kind = root;

    field id : string { required = true; }
    field workflow_state : string { label = "Workflow State"; }
    field contract_name : string { label = "Contract Name"; }
    field vendor : string { label = "Vendor"; }
    field start_date : date { label = "Start Date"; }
    field end_date : date { label = "End Date"; }
    field contract_value : decimal { label = "Contract Value"; }
    field payment_terms : string { label = "Payment Terms"; }
    field site : string { label = "Site"; }
    field description : text { label = "Description"; }
    field auto_renew : boolean { label = "Auto Renew"; default = false; }
    field renewal_notice_days : integer { label = "Renewal Notice Days"; }

    relation vendor-ref {
      from = purchasing_stores.ServiceContract.vendor;
      to = purchasing_stores.Vendor.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation site-ref {
      from = purchasing_stores.ServiceContract.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.service-contract-lifecycle;
  }

  entity VendorInvoice {
    label = "Vendor Invoice";
    category = transactional;
    kind = root;

    field id : string { required = true; }
    field workflow_state : string { label = "Workflow State"; }
    field invoice_number : string { label = "Invoice Number"; }
    field invoice_date : date { label = "Invoice Date"; }
    field due_date : date { label = "Due Date"; }
    field vendor : string { label = "Vendor"; }
    field purchase_order : string { label = "Purchase Order"; }
    field currency : string { label = "Currency"; }
    field subtotal : decimal { label = "Subtotal"; }
    field tax_amount : decimal { label = "Tax Amount"; }
    field total_amount : decimal { label = "Total Amount"; }
    field site : string { label = "Site"; }
    field match_status : string { label = "Match Status"; }
    field payment_reference : string { label = "Payment Reference"; }

    relation vendor-ref {
      from = purchasing_stores.VendorInvoice.vendor;
      to = purchasing_stores.Vendor.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation po-ref {
      from = purchasing_stores.VendorInvoice.purchase_order;
      to = purchasing_stores.PurchaseOrder.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation currency-ref {
      from = purchasing_stores.VendorInvoice.currency;
      to = purchasing_stores.Currency.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation site-ref {
      from = purchasing_stores.VendorInvoice.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.vendor-invoice-lifecycle;

    behavior {
      workflow use purchasing_stores.vendor-invoice-workflow;

      on match {
        do = purchasing_stores.three-way-match;
      }

      permissions {
        role core.admin {
          allow = read, write, create, delete;
        }
        role core.manager {
          allow = read, write, create, submit, approve;
        }
        role core.storekeeper {
          allow = read, write, create, submit;
        }
        role core.viewer {
          allow = read;
        }
      }
    }
  }

  entity VendorInvoiceLine {
    label = "Vendor Invoice Line";
    category = transactional;
    kind = child;

    field id : string { required = true; }
    field vendor_invoice : string { label = "Vendor Invoice"; }
    field item : string { label = "Item"; }
    field description : text { label = "Description"; }
    field quantity : integer { label = "Quantity"; }
    field unit_cost : decimal { label = "Unit Cost"; }
    field total_cost : decimal { label = "Total Cost"; }
    field po_line : string { label = "PO Line"; }

    relation invoice-ref {
      from = purchasing_stores.VendorInvoiceLine.vendor_invoice;
      to = purchasing_stores.VendorInvoice.id;
      kind = composition;
      cardinality = many-to-one;
    }

    relation item-ref {
      from = purchasing_stores.VendorInvoiceLine.item;
      to = purchasing_stores.Item.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation po-line-ref {
      from = purchasing_stores.VendorInvoiceLine.po_line;
      to = purchasing_stores.PurchaseOrderLine.id;
      kind = association;
      cardinality = many-to-one;
    }
  }

  (* ========================================== *)
  (* ENTITIES — SALES ORDER                     *)
  (* ========================================== *)

  entity SalesOrder {
    label = "Sales Order";
    category = transactional;
    kind = root;

    field id : string { required = true; }
    field workflow_state : string { label = "Workflow State"; }
    field order_date : date { label = "Order Date"; }
    field customer_name : string { label = "Customer Name"; }
    field site : string { label = "Site"; }
    field store : string { label = "Store"; }
    field total_amount : decimal { label = "Total Amount"; }
    field notes : text { label = "Notes"; }

    relation site-ref {
      from = purchasing_stores.SalesOrder.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation store-ref {
      from = purchasing_stores.SalesOrder.store;
      to = purchasing_stores.Store.id;
      kind = association;
      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.sales-order-lifecycle;

    behavior {
      workflow use purchasing_stores.sales-order-workflow;
    }
  }

  entity SalesOrderItem {
    label = "Sales Order Item";
    category = transactional;
    kind = child;

    field id : string { required = true; }
    field sales_order : string { label = "Sales Order"; }
    field item : string { label = "Item"; }
    field quantity : integer { label = "Quantity"; }
    field unit_price : decimal { label = "Unit Price"; }
    field total_price : decimal { label = "Total Price"; }

    relation so-ref {
      from = purchasing_stores.SalesOrderItem.sales_order;
      to = purchasing_stores.SalesOrder.id;
      kind = composition;
      cardinality = many-to-one;
    }

    relation item-ref {
      from = purchasing_stores.SalesOrderItem.item;
      to = purchasing_stores.Item.id;
      kind = association;
      cardinality = many-to-one;
    }
  }

  (* ========================================== *)
  (* ACTIONS                                    *)
  (* ========================================== *)

  action validate-budget {
    kind = server;
    entity = purchasing_stores.PurchaseRequest;
    handler = "purchasing_stores.hooks.purchase_request_hooks.validate_budget";
  }

  action send-po-to-vendor {
    kind = server;
    entity = purchasing_stores.PurchaseOrder;
    handler = "purchasing_stores.hooks.purchase_order_hooks.send_to_vendor";
  }

  action three-way-match {
    kind = server;
    entity = purchasing_stores.VendorInvoice;
    handler = "purchasing_stores.hooks.vendor_invoice_hooks.three_way_match";
  }

  action deduct-inventory {
    kind = server;
    entity = purchasing_stores.ItemIssue;
    handler = "purchasing_stores.hooks.item_issue_hooks.deduct_inventory";
  }

  action restore-inventory {
    kind = server;
    entity = purchasing_stores.ItemReturn;
    handler = "purchasing_stores.hooks.item_return_hooks.restore_inventory";
  }

  action post-adjustment-to-ledger {
    kind = server;
    entity = purchasing_stores.InventoryAdjustment;
    handler = "purchasing_stores.hooks.adjustment_hooks.post_to_ledger";
  }

  action generate-count-adjustments {
    kind = server;
    entity = purchasing_stores.StockCount;
    handler = "purchasing_stores.hooks.stock_count_hooks.generate_adjustments";
  }

  action check-reorder-levels {
    kind = scheduled;
    entity = purchasing_stores.Inventory;
    handler = "purchasing_stores.scheduled_jobs.check_reorder_levels";
  }

  action check-contract-expiry {
    kind = scheduled;
    entity = purchasing_stores.ServiceContract;
    handler = "purchasing_stores.scheduled_jobs.check_contract_expiry";
  }

  (* ========================================== *)
  (* AUTOMATIONS                                *)
  (* ========================================== *)

  automation reorder-monitoring {
    entity = purchasing_stores.Inventory;
    trigger daily-reorder-check {
      schedule = "0 2 * * *";
      invoke = purchasing_stores.check-reorder-levels;
    }
  }

  automation contract-expiry-monitor {
    entity = purchasing_stores.ServiceContract;
    trigger daily-expiry-check {
      schedule = "0 7 * * *";
      invoke = purchasing_stores.check-contract-expiry;
    }
  }

  (* ========================================== *)
  (* METRICS                                    *)
  (* ========================================== *)

  metrics procurement-metrics {
    metric open-purchase-orders {
      entity = purchasing_stores.PurchaseOrder;
      aggregation = count;
    }

    metric total-po-value {
      entity = purchasing_stores.PurchaseOrder;
      field = total_amount;
      aggregation = sum;
    }

    metric pending-invoices {
      entity = purchasing_stores.VendorInvoice;
      aggregation = count;
    }

    metric inventory-value {
      entity = purchasing_stores.Inventory;
      field = total_value;
      aggregation = sum;
    }

    metric stock-turnover {
      entity = purchasing_stores.StockLedgerEntry;
      aggregation = count;
    }

    metric overdue-invoices {
      entity = purchasing_stores.VendorInvoice;
      aggregation = count;
    }

    metric active-contracts {
      entity = purchasing_stores.ServiceContract;
      aggregation = count;
    }

    report inventory-valuation-report {
      entity = purchasing_stores.Inventory;
      kind = tabular;
    }

    report procurement-spend-report {
      entity = purchasing_stores.PurchaseOrder;
      kind = tabular;
    }
  }

}
