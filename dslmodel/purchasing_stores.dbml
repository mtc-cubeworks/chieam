      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.item-return-lifecycle;

    behavior {
      workflow use purchasing_stores.item-return-workflow;

      on return-items {
        do = purchasing_stores.restore-inventory;
      }
    }
  }

  entity ItemReturnLine {
    label = "Item Return Line";
    category = transactional;
    kind = child;

    field id : string { required = true; }
