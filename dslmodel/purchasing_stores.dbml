    }
  }

  (* ========================================== *)
  (* ENTITIES — PURCHASING                      *)
  (* ========================================== *)

  entity PurchaseRequest {
    label = "Purchase Request";
    category = transactional;
    kind = root;

    field id : string { required = true; }
    field workflow_state : string { label = "Workflow State"; }
    field request_date : date { label = "Request Date"; }
    field required_date : date { label = "Required Date"; }
    field site : string { label = "Site"; }
    field department : string { label = "Department"; }
    field requested_by : string { label = "Requested By"; }
    field approved_by : string { label = "Approved By"; }
    field work_order : string { label = "Work Order"; }
    field description : text { label = "Description"; }
    field total_amount : decimal { label = "Total Amount"; }
    field budget_validation_status : string { label = "Budget Validation Status"; }

    relation site-ref {
      from = purchasing_stores.PurchaseRequest.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation dept-ref {
      from = purchasing_stores.PurchaseRequest.department;
      to = core.Department.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation requested-ref {
      from = purchasing_stores.PurchaseRequest.requested_by;
      to = core.Employee.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation approved-ref {
      from = purchasing_stores.PurchaseRequest.approved_by;
      to = core.Employee.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation wo-ref {
      from = purchasing_stores.PurchaseRequest.work_order;
      to = work.WorkOrder.id;
      kind = association;
      cardinality = many-to-one;
    }

    lifecycle use purchasing_stores.purchase-request-lifecycle;

    behavior {
      workflow use purchasing_stores.purchase-request-workflow;

      on submit {
        do = purchasing_stores.validate-budget;
      }

      permissions {
        role core.admin {
          allow = read, write, create, delete;
        }
        role core.manager {
          allow = read, write, create, submit, approve;
        }
        role core.requester {
          allow = read, write, create, submit;
        }
        role core.storekeeper {
          allow = read, write, create, submit;
        }
        role core.viewer {
          allow = read;
        }
      }
    }
  }

  entity PurchaseRequestLine {
    label = "Purchase Request Line";
    category = transactional;
    kind = child;

    field id : string { required = true; }
    field purchase_request : string { label = "Purchase Request"; }
