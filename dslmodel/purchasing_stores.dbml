    relation site-ref {
      from = purchasing_stores.ItemReturn.site;
      to = core.Site.id;
      kind = association;
      cardinality = many-to-one;
    }

    relation returned-ref {
      from = purchasing_stores.ItemReturn.returned_by;
      to = core.Employee.id;
      kind = association;
