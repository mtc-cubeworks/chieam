/* ================================================================= */
/*  EAM-CHI Operational Technology Model (OTML v1.7)                  */
/*  Enterprise Asset Management – CHI Implementation                  */
/*  OT/SCADA/DCS Integration for Condition-Based Maintenance          */
/* ================================================================= */

namespace chi.eam.ot version "1.0.0";

import "core_eam.dbml" as core;
import "asset_management.dbml" as asset;
import "maintenance_mgmt.dbml" as maint;

/* ================================================================= */
/*  META                                                               */
/* ================================================================= */

Meta "eam-ot-model" {
  project: "CHI Enterprise Asset Management";
  domain: "Industrial OT/SCADA Integration";
  standard: "ISA-95 / IEC-62264";
  version: "1.0.0";
}

/* ================================================================= */
/*  SYSTEM BLOCKS                                                      */
/* ================================================================= */

SystemBlock "chi-plant" {
  domain: "Manufacturing / Facilities";
  area: "Main Plant";
  node: chi.eam.ot.edge_gateway_01;
  node: chi.eam.ot.edge_gateway_02;
  node: chi.eam.ot.plc_cabinet_01;
  node: chi.eam.ot.plc_cabinet_02;
  node: chi.eam.ot.scada_server;
}

SystemBlock "chi-utilities" {
  domain: "Utilities / HVAC";
  area: "Utility Block";
  node: chi.eam.ot.edge_gateway_03;
  node: chi.eam.ot.plc_cabinet_03;
}

/* ================================================================= */
/*  NODES                                                              */
/* ================================================================= */

Node "edge_gateway_01" {
  role: "edge";
  location: "Main Plant – Zone A";
  endpoint: chi.eam.ot.ep_mqtt_gw01;
  endpoint: chi.eam.ot.ep_modbus_gw01;
}

Node "edge_gateway_02" {
  role: "edge";
  location: "Main Plant – Zone B";
  endpoint: chi.eam.ot.ep_mqtt_gw02;
  endpoint: chi.eam.ot.ep_modbus_gw02;
}

Node "edge_gateway_03" {
  role: "edge";
  location: "Utility Block";
  endpoint: chi.eam.ot.ep_mqtt_gw03;
}

Node "plc_cabinet_01" {
  role: "plc_cabinet";
  location: "Main Plant – Zone A MCC Room";
  endpoint: chi.eam.ot.ep_plc01;
}

Node "plc_cabinet_02" {
  role: "plc_cabinet";
  location: "Main Plant – Zone B MCC Room";
  endpoint: chi.eam.ot.ep_plc02;
}

Node "plc_cabinet_03" {
  role: "plc_cabinet";
  location: "Utility Block MCC Room";
  endpoint: chi.eam.ot.ep_plc03;
}

Node "scada_server" {
  role: "gateway";
  location: "Control Room";
  endpoint: chi.eam.ot.ep_opcua_scada;
}

/* ================================================================= */
/*  DEVICE CLASSES                                                     */
/* ================================================================= */

DeviceClass "esp32_edge" {
  vendor: "Espressif";
  model: "ESP32-S3";
  cpu: "ESP32-S3 Dual-core LX7";
  capabilities: ["wifi", "ble", "mqtt", "modbus_rtu", "i2c", "spi", "adc"];
}

DeviceClass "siemens_s71500" {
  vendor: "Siemens";
  model: "S7-1500";
  cpu: "CPU 1515-2 PN";
  capabilities: ["profinet", "opcua", "modbus_tcp", "web_server"];
}

DeviceClass "ab_compactlogix" {
  vendor: "Allen-Bradley";
  model: "CompactLogix 5380";
  cpu: "5069-L330ER";
  capabilities: ["ethernet_ip", "opcua", "modbus_tcp"];
}

DeviceClass "vibration_sensor" {
  vendor: "SKF";
  model: "CMSS 2200";
  capabilities: ["4-20mA", "modbus_rtu", "vibration_spectrum"];
}

DeviceClass "temp_sensor" {
  vendor: "Honeywell";
  model: "STT850";
  capabilities: ["4-20mA", "hart", "modbus_rtu"];
}

DeviceClass "pressure_sensor" {
  vendor: "Endress+Hauser";
  model: "Cerabar PMC71";
  capabilities: ["4-20mA", "hart", "modbus_rtu", "profinet"];
}

DeviceClass "flow_sensor" {
  vendor: "Endress+Hauser";
  model: "Promag 400";
  capabilities: ["4-20mA", "hart", "modbus_rtu", "profinet"];
}

DeviceClass "level_sensor" {
  vendor: "Endress+Hauser";
  model: "Levelflex FMP50";
  capabilities: ["4-20mA", "hart", "modbus_rtu"];
}

DeviceClass "motor_drive" {
  vendor: "ABB";
  model: "ACS580";
  capabilities: ["modbus_rtu", "profinet", "ethernet_ip", "opcua"];
}

/* ================================================================= */
/*  PROFILES                                                           */
/* ================================================================= */

Profile "edge_sensor_profile" {
  uses chi.eam.ot.esp32_edge;
  defaults: {
    wifi_mode: "STA";
    mqtt_broker: "mqtt://scada.chi.local:1883";
    log_level: "INFO";
    ota_enabled: true;
    sample_interval: "1s";
    publish_interval: "5s";
    watchdog_timeout: "30s";
  };
}

Profile "plc_standard_profile" {
  uses chi.eam.ot.siemens_s71500;
  defaults: {
    scan_cycle: "10ms";
    opcua_enabled: true;
    opcua_port: 4840;
    web_server_enabled: true;
    safe_state: "STOP";
  };
}

/* ================================================================= */
/*  ENDPOINTS                                                          */
/* ================================================================= */

Endpoint "ep_mqtt_gw01" {
  uses chi.eam.ot.edge_sensor_profile;
  protocol: "MQTT";
  address: "mqtt://scada.chi.local:1883";
  timers: { fast10ms: 10ms; sensor_poll: 1s; publish: 5s };
  policies: { watchdog: 30s; safe_state: "last_known_value"; reconnect: true };
}

Endpoint "ep_modbus_gw01" {
  uses chi.eam.ot.edge_sensor_profile;
  protocol: "Modbus_RTU";
  address: "/dev/ttyUSB0:9600:8N1";
  timers: { poll_cycle: 500ms };
}

Endpoint "ep_mqtt_gw02" {
  uses chi.eam.ot.edge_sensor_profile;
  protocol: "MQTT";
  address: "mqtt://scada.chi.local:1883";
  timers: { fast10ms: 10ms; sensor_poll: 1s; publish: 5s };
  policies: { watchdog: 30s; safe_state: "last_known_value"; reconnect: true };
}

Endpoint "ep_modbus_gw02" {
  uses chi.eam.ot.edge_sensor_profile;
  protocol: "Modbus_RTU";
  address: "/dev/ttyUSB1:9600:8N1";
  timers: { poll_cycle: 500ms };
}

Endpoint "ep_mqtt_gw03" {
  uses chi.eam.ot.edge_sensor_profile;
  protocol: "MQTT";
  address: "mqtt://scada.chi.local:1883";
  timers: { sensor_poll: 2s; publish: 10s };
  policies: { watchdog: 60s; safe_state: "last_known_value" };
}

Endpoint "ep_plc01" {
  uses chi.eam.ot.plc_standard_profile;
  protocol: "OPCUA";
  address: "opc.tcp://plc01.chi.local:4840";
  timers: { scan: 10ms; opcua_publish: 100ms };
}

Endpoint "ep_plc02" {
  uses chi.eam.ot.plc_standard_profile;
  protocol: "OPCUA";
  address: "opc.tcp://plc02.chi.local:4840";
  timers: { scan: 10ms; opcua_publish: 100ms };
}

Endpoint "ep_plc03" {
  uses chi.eam.ot.plc_standard_profile;
  protocol: "OPCUA";
  address: "opc.tcp://plc03.chi.local:4840";
  timers: { scan: 20ms; opcua_publish: 200ms };
}

Endpoint "ep_opcua_scada" {
  protocol: "OPCUA";
  address: "opc.tcp://scada.chi.local:4840";
  policies: { auth: "certificate"; encryption: "Basic256Sha256" };
}

/* ================================================================= */
/*  INSTRUMENTS                                                        */
/* ================================================================= */

/* ------------- Vibration Sensors --------------------------------- */

Instrument "VIB_PUMP_01" {
  type: "VibrationTransmitter";
  role: "measure";
  variable: "vibration_velocity";
  eu: "mm/s";
  range: [0, 50];
  sample: 500ms;
  connect: endpoint chi.eam.ot.ep_modbus_gw01."40001";
  historians: ["chi_historian"];
}

Instrument "VIB_PUMP_02" {
  type: "VibrationTransmitter";
  role: "measure";
  variable: "vibration_velocity";
  eu: "mm/s";
  range: [0, 50];
  sample: 500ms;
  connect: endpoint chi.eam.ot.ep_modbus_gw01."40003";
  historians: ["chi_historian"];
}

Instrument "VIB_MOTOR_01" {
  type: "VibrationTransmitter";
  role: "measure";
  variable: "vibration_acceleration";
  eu: "g";
  range: [0, 20];
  sample: 500ms;
  connect: endpoint chi.eam.ot.ep_modbus_gw02."40001";
  historians: ["chi_historian"];
}

Instrument "VIB_FAN_01" {
  type: "VibrationTransmitter";
  role: "measure";
  variable: "vibration_velocity";
  eu: "mm/s";
  range: [0, 30];
  sample: 1s;
  connect: endpoint chi.eam.ot.ep_modbus_gw02."40003";
  historians: ["chi_historian"];
}

/* ------------- Temperature Sensors ------------------------------- */

Instrument "TEMP_BEARING_01" {
  type: "TemperatureTransmitter";
  role: "measure";
  variable: "temperature";
  eu: "degC";
  range: [0, 200];
  sample: 2s;
  connect: endpoint chi.eam.ot.ep_modbus_gw01."40010";
  historians: ["chi_historian"];
}

Instrument "TEMP_BEARING_02" {
  type: "TemperatureTransmitter";
  role: "measure";
  variable: "temperature";
  eu: "degC";
  range: [0, 200];
  sample: 2s;
  connect: endpoint chi.eam.ot.ep_modbus_gw01."40012";
  historians: ["chi_historian"];
}

Instrument "TEMP_MOTOR_01" {
  type: "TemperatureTransmitter";
  role: "measure";
  variable: "winding_temperature";
  eu: "degC";
  range: [0, 250];
  sample: 5s;
  connect: endpoint chi.eam.ot.ep_modbus_gw02."40010";
  historians: ["chi_historian"];
}

Instrument "TEMP_HVAC_SUPPLY" {
  type: "TemperatureTransmitter";
  role: "measure";
  variable: "supply_air_temp";
  eu: "degC";
