    /* ------------- Asset Tables ---------------------------------- */

    dataTable dt_assets {
      title: "Assets";
      bind-entity: asset.Asset;
      pagination: true;
      rowInteraction: int_open_detail;

      columns {
        column col_code {
          header: "Asset Code";
          field: "asset_code";
          type: string;
          width: "120px";
        }
        column col_desc {
          header: "Description";
          field: "description";
          type: string;
        }
        column col_class {
          header: "Class";
          field: "asset_class.name";
          type: string;
          width: "140px";
        }
        column col_location {
          header: "Location";
          field: "location.description";
          type: string;
        }
        column col_status {
          header: "Status";
          field: "status";
          type: badge;
          width: "100px";
        }
        column col_criticality {
          header: "Criticality";
          field: "criticality";
          type: badge;
          width: "100px";
        }
      }

      actions {
        tableAction ta_create {
          label: "New Asset";
          kind: primary;
          icon: "mdi-plus";
          interaction: int_navigate_create_asset;
        }
        tableAction ta_export {
          label: "Export";
          kind: secondary;
          icon: "mdi-download";
          interaction: int_export_list;
        }
        tableAction ta_view {
          label: "View";
          kind: row;
          icon: "mdi-eye";
          interaction: int_open_detail;
        }
        tableAction ta_edit {
          label: "Edit";
          kind: row;
          icon: "mdi-pencil";
          interaction: int_open_edit;
        }
      }
    }

