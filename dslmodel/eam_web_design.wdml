      actions {
        tableAction ta_create {
          label: "New Item";
          kind: primary;
          icon: "mdi-plus";
          interaction: int_navigate_create;
        }
      }
    }

    /* ------------- Admin Tables ---------------------------------- */

    dataTable dt_employees {
      title: "Employees";
      bind-entity: core.Employee;
      pagination: true;
      rowInteraction: int_open_detail;

      columns {
        column col_number {
          header: "Emp #";
          field: "employee_number";
          type: string;
          width: "100px";
        }
        column col_name {
          header: "Name";
          field: "full_name";
          type: string;
        }
        column col_dept {
          header: "Department";
          field: "department.name";
          type: string;
          width: "140px";
        }
        column col_email {
          header: "Email";
          field: "email";
          type: string;
        }
        column col_active {
          header: "Active";
          field: "is_active";
          type: boolean;
          width: "80px";
        }
      }

      actions {
        tableAction ta_create {
          label: "New Employee";
          kind: primary;
          icon: "mdi-plus";
          interaction: int_navigate_create;
        }
      }
    }

    dataTable dt_sites {
      title: "Sites";
      bind-entity: core.Site;
      pagination: true;

      columns {
        column col_code {
          header: "Code";
          field: "code";
          type: string;
          width: "100px";
        }
        column col_name {
          header: "Name";
          field: "name";
          type: string;
        }
        column col_org {
          header: "Organization";
          field: "organization.name";
          type: string;
          width: "150px";
        }
      }

      actions {
        tableAction ta_create {
          label: "New Site";
          kind: primary;
          icon: "mdi-plus";
          interaction: int_navigate_create;
        }
      }
    }

    /* ============================================================= */
    /*  MODALS                                                         */
    /* ============================================================= */

    modal modal_confirm_delete {
      title: "Confirm Delete";
      size: sm;
      primaryAction: int_confirm_delete;
      secondaryAction: int_close_modal;
    }

    modal modal_workflow_transition {
      title: "Workflow Action";
      size: md;
      content-view: ux.eam_chi.workflow_status_badge;
      primaryAction: int_confirm_transition;
      secondaryAction: int_close_modal;
    }

    modal modal_approve {
      title: "Approve Record";
      size: md;
      primaryAction: int_confirm_approve;
      secondaryAction: int_close_modal;
    }

    modal modal_reject {
      title: "Reject Record";
      size: md;
      primaryAction: int_confirm_reject;
      secondaryAction: int_close_modal;
    }

    modal modal_meter_reading {
      title: "Record Meter Reading";
      size: md;
      primaryAction: int_submit_entity;
      secondaryAction: int_close_modal;
    }

    modal modal_add_line_item {
      title: "Add Line Item";
      size: lg;
      primaryAction: int_submit_entity;
      secondaryAction: int_close_modal;
    }

    modal modal_three_way_match {
      title: "Three-Way Match Result";
      size: lg;
      content-view: ux.eam_chi.purchasing;
      primaryAction: int_confirm_approve;
      secondaryAction: int_close_modal;
    }

    /* ============================================================= */
    /*  DRAWERS                                                        */
    /* ============================================================= */

    drawer drawer_asset_detail {
      title: "Asset Quick View";
      position: right;
      content-view: ux.eam_chi.asset_detail_view;
      primaryAction: int_open_edit;
      secondaryAction: int_close_drawer;
    }

    drawer drawer_wo_detail {
      title: "Work Order Quick View";
      position: right;
      content-view: ux.eam_chi.work_order_detail_view;
      primaryAction: int_open_edit;
      secondaryAction: int_close_drawer;
    }

    drawer drawer_notifications {
      title: "Notifications";
      position: right;
    }

    drawer drawer_filters {
      title: "Advanced Filters";
      position: right;
    }

    drawer drawer_activity_log {
      title: "Activity Log";
      position: right;
    }

    /* ============================================================= */
    /*  INTERACTIONS                                                    */
    /* ============================================================= */

    /* ------------- Navigation Interactions ------------------------ */

    interaction int_navigate_create {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/new";
      }
    }

    interaction int_navigate_create_asset {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/assets/new";
      }
    }

    interaction int_navigate_create_mr {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/maintenance/requests/new";
      }
    }

    interaction int_navigate_create_wo {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/work-orders/new";
      }
    }

    interaction int_navigate_issue {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/inventory/issues/new";
      }
    }

    interaction int_navigate_adjustment {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/inventory/adjustments/new";
      }
    }

    interaction int_open_detail {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/{entity}/{id}";
      }
    }

    interaction int_open_edit {
      trigger: "click";
      action act_nav {
        kind: navigate;
        navigateTo: "/{entity}/{id}/edit";
      }
    }

    /* ------------- Modal Interactions ---------------------------- */

    interaction int_open_delete_modal {
      trigger: "click";
      action act_modal {
        kind: openModal;
        modal: modal_confirm_delete;
      }
    }

    interaction int_close_modal {
      trigger: "click";
      action act_close {
        kind: closeModal;
      }
    }

    interaction int_open_workflow_modal {
      trigger: "click";
      action act_modal {
        kind: openModal;
        modal: modal_workflow_transition;
      }
    }

    /* ------------- Drawer Interactions ---------------------------- */

    interaction int_open_asset_drawer {
      trigger: "click";
      action act_drawer {
        kind: openDrawer;
        drawer: drawer_asset_detail;
      }
    }

    interaction int_open_wo_drawer {
      trigger: "click";
      action act_drawer {
        kind: openDrawer;
        drawer: drawer_wo_detail;
      }
    }

    interaction int_open_notifications {
      trigger: "click";
      action act_drawer {
        kind: openDrawer;
        drawer: drawer_notifications;
      }
    }

    interaction int_open_filters {
      trigger: "click";
      action act_drawer {
        kind: openDrawer;
        drawer: drawer_filters;
      }
    }

    interaction int_close_drawer {
      trigger: "click";
      action act_close {
        kind: closeDrawer;
      }
    }

    /* ------------- UXML-Delegated Interactions ------------------- */

    interaction int_submit_asset {
      trigger: "submit";
      action act_uxml {
        kind: uxml;
        invoke-uxml: ux.eam_chi.asset_management;
        toast: "Asset saved successfully";
      }
    }

    interaction int_submit_maintenance_request {
      trigger: "submit";
      action act_uxml {
        kind: uxml;
        invoke-uxml: ux.eam_chi.maintenance;
        toast: "Maintenance request submitted";
      }
    }

    interaction int_submit_work_order {
      trigger: "submit";
      action act_uxml {
        kind: uxml;
        invoke-uxml: ux.eam_chi.work_order;
        toast: "Work order saved";
      }
    }

    interaction int_submit_purchase_request {
      trigger: "submit";
      action act_uxml {
        kind: uxml;
        invoke-uxml: ux.eam_chi.purchasing;
        toast: "Purchase request submitted";
      }
    }

    interaction int_submit_purchase_order {
      trigger: "submit";
      action act_uxml {
        kind: uxml;
        invoke-uxml: ux.eam_chi.purchasing;
        toast: "Purchase order saved";
      }
    }

    interaction int_submit_entity {
      trigger: "submit";
      action act_uxml {
        kind: uxml;
        toast: "Record saved successfully";
      }
    }

    /* ------------- Workflow Interactions -------------------------- */

    interaction int_approve_request {
      trigger: "click";
      action act_approve {
        kind: uxml;
        toast: "Record approved";
      }
    }

    interaction int_confirm_approve {
      trigger: "click";
      action act_approve {
        kind: uxml;
        toast: "Approved successfully";
      }
    }

    interaction int_confirm_reject {
      trigger: "click";
      action act_reject {
        kind: uxml;
        toast: "Record rejected";
      }
    }

    interaction int_confirm_delete {
      trigger: "click";
      action act_delete {
        kind: uxml;
        toast: "Record deleted";
      }
    }

    interaction int_confirm_transition {
      trigger: "click";
      action act_transition {
        kind: uxml;
        toast: "Workflow transition complete";
      }
    }

    interaction int_start_work_order {
      trigger: "click";
      action act_start {
        kind: uxml;
        invoke-uxml: ux.eam_chi.work_order;
        toast: "Work order started";
      }
    }

    interaction int_complete_work_order {
      trigger: "click";
      action act_complete {
        kind: uxml;
        invoke-uxml: ux.eam_chi.work_order;
        toast: "Work order completed";
      }
    }

    interaction int_send_to_vendor {
      trigger: "click";
      action act_send {
        kind: uxml;
        invoke-uxml: ux.eam_chi.purchasing;
        toast: "PO sent to vendor";
      }
    }

    interaction int_three_way_match {
      trigger: "click";
      action act_match {
        kind: openModal;
        modal: modal_three_way_match;
      }
    }

    interaction int_export_list {
      trigger: "click";
      action act_export {
        kind: showToast;
        toast: "Export started. File will download shortly.";
      }
    }

    /* ============================================================= */
    /*  PAGE DESIGNS                                                   */
    /* ============================================================= */

    /* ------------- Dashboard ------------------------------------- */

    pageDesign page_dashboard {
      meta {
        title: "Dashboard";
        description: "EAM operations overview with KPIs and charts";
        audience: "All EAM users";
      }
      route: "/dashboard";
      layoutPattern: eam_ds.lp_stack;
      bind-feature: ux.eam_chi.dashboard;

      section sec_kpis {
        kind: stats;
        layoutPattern: eam_ds.lp_card_grid;

        data kpi_block {
          kind: kpiGrid;

          item kpi_open_wo {
            label: "Open Work Orders";
            value: "dynamic";
            icon: "mdi-clipboard-text";
          }
          item kpi_overdue_wo {
            label: "Overdue Work Orders";
            value: "dynamic";
            icon: "mdi-alert";
          }
          item kpi_pm_compliance {
            label: "PM Compliance";
            value: "dynamic";
            icon: "mdi-check-circle";
          }
          item kpi_asset_availability {
            label: "Asset Availability";
            value: "dynamic";
            icon: "mdi-cog-box";
          }
          item kpi_pending_pr {
            label: "Pending PRs";
            value: "dynamic";
            icon: "mdi-cart-arrow-up";
          }
          item kpi_low_stock {
            label: "Low Stock Alerts";
            value: "dynamic";
            icon: "mdi-package-variant-closed";
          }
        }
      }

      section sec_charts {
        kind: dashboard;
        layoutPattern: eam_ds.lp_card_grid;

        heading hd_charts {
          text: "Operational Overview";
          style: eam_ds.txt_h2;
          level: 2;
        }

        slot slot_wo_trend {
          role: card;
          component: ux.eam_chi.chart_widget;
        }

        slot slot_mtbf_chart {
          role: card;
          component: ux.eam_chi.chart_widget;
        }

        slot slot_inventory_chart {
          role: card;
          component: ux.eam_chi.chart_widget;
        }

        slot slot_cost_chart {
          role: card;
          component: ux.eam_chi.chart_widget;
        }
      }

      section sec_recent_wo {
        kind: dataTable;
        dataTableRef: dt_work_orders;

        heading hd_recent {
          text: "Recent Work Orders";
          style: eam_ds.txt_h3;
          level: 3;
        }
      }

      section sec_recent_mr {
        kind: dataTable;
        dataTableRef: dt_maintenance_requests;

        heading hd_recent_mr {
          text: "Recent Maintenance Requests";
          style: eam_ds.txt_h3;
          level: 3;
        }
      }

      implementation impl_dashboard {
        framework: nuxt;
        css: tailwind;

        map map_stat {
          from: sectionKind: stats;
          to: "components/dashboard/KpiCards.vue";
        }
        map map_chart {
          from: sectionKind: dashboard;
          to: "components/dashboard/ChartGrid.vue";
        }
      }
    }

    /* ------------- Asset List Page ------------------------------- */

    pageDesign page_asset_list {
      meta {
        title: "Assets";
        description: "Browse and manage all registered assets";
      }
      route: "/assets";
      layoutPattern: eam_ds.lp_stack;
