/* ================================================================= */
/*  EAM-CHI Web Design Model (WDML v3.3)                            */
/*  Enterprise Asset Management – CHI Implementation                 */
/*  Generated from completed system: 120 models across 5 modules     */
/* ================================================================= */

wdml model eam_chi_web {

  import "core_eam.dbml" as core;
  import "asset_management.dbml" as asset;
  import "maintenance_mgmt.dbml" as maint;
  import "work_mgmt.dbml" as work;
  import "purchasing_stores.dbml" as purch;
  import "eam_ux.uxml" as ux;

  /* =============================================================== */
  /*  DESIGN SYSTEM                                                   */
  /* =============================================================== */

  designSystem eam_ds {

    meta {
      title: "EAM-CHI Design System";
      description: "Enterprise asset management design tokens and component themes";
      brand: "CHI EAM";
      version: "1.0.0";
    }

    /* ------------- Color Tokens ---------------------------------- */

    color clr_primary {
      role: primary;
      value: "#1565C0";
      usage: "Primary brand blue for nav, buttons, links";
    }

    color clr_primary_soft {
      role: primarySoft;
      value: "#E3F2FD";
      usage: "Light primary for backgrounds, hover states";
    }

    color clr_secondary {
      role: secondary;
      value: "#37474F";
      usage: "Dark slate for secondary actions, headers";
    }

    color clr_accent {
      role: accent;
      value: "#FF6F00";
      usage: "Amber accent for highlights, badges";
    }

    color clr_neutral {
      role: neutral;
      value: "#78909C";
      usage: "Blue-grey neutral for borders, dividers";
    }

    color clr_danger {
      role: danger;
      value: "#D32F2F";
      usage: "Red for errors, critical alerts, overdue items";
    }

    color clr_success {
      role: success;
      value: "#2E7D32";
      usage: "Green for completed, approved, operational states";
    }

    color clr_warning {
      role: warning;
      value: "#F9A825";
      usage: "Yellow for pending, caution, approaching deadlines";
    }

    color clr_info {
      role: info;
      value: "#0288D1";
      usage: "Light blue for informational notices";
    }

    color clr_background {
      role: background;
      value: "#F5F5F5";
      usage: "Page background, light grey";
    }

    color clr_surface {
      role: surface;
      value: "#FFFFFF";
      usage: "Card and panel background";
    }

    color clr_text_primary {
      role: textPrimary;
      value: "#212121";
      usage: "Primary text color";
    }

    color clr_text_secondary {
      role: textSecondary;
      value: "#616161";
      usage: "Secondary text, labels, hints";
    }

    /* ------------- Hover/Active State Colors --------------------- */

    color clr_primary_hover {
      role: primary;
      state: hover;
      value: "#0D47A1";
      usage: "Darker blue on hover";
    }

    color clr_primary_active {
      role: primary;
      state: active;
      value: "#0A3D91";
      usage: "Darkest blue on click";
    }

    color clr_danger_hover {
      role: danger;
      state: hover;
      value: "#B71C1C";
      usage: "Darker red on hover";
    }

    /* ------------- Spacing Tokens -------------------------------- */

    space sp_xs {
      step: 4;
      usage: "Extra small - inline icon gap";
    }

    space sp_sm {
      step: 8;
      usage: "Small - input padding, tight gap";
    }

    space sp_md {
      step: 16;
      usage: "Medium - card padding, section gap";
    }

    space sp_lg {
      step: 24;
      usage: "Large - section spacing";
    }

    space sp_xl {
      step: 32;
      usage: "Extra large - page margin";
    }

    space sp_2xl {
      step: 48;
      usage: "Double extra large - hero section padding";
    }

    /* ------------- Radius Tokens --------------------------------- */

    radius rad_sm {
      value: 4;
      usage: "Subtle rounding for inputs, badges";
    }

    radius rad_md {
      value: 8;
      usage: "Standard card and panel rounding";
    }

    radius rad_lg {
      value: 12;
      usage: "Prominent rounding for modals, popovers";
    }

    radius rad_full {
      value: 999;
      usage: "Pill shape for chips, avatar";
    }

    /* ------------- Shadow Tokens --------------------------------- */

    shadow shd_sm {
      value: "0 1px 3px rgba(0,0,0,0.12)";
      usage: "Subtle shadow for cards";
    }

    shadow shd_md {
      value: "0 4px 6px rgba(0,0,0,0.15)";
      usage: "Elevated cards, dropdowns";
    }

    shadow shd_lg {
      value: "0 10px 25px rgba(0,0,0,0.2)";
      usage: "Modals, drawers";
    }

    /* ------------- Typography ------------------------------------ */

    fontFamily ff_sans {
      stack: "'Inter', 'Segoe UI', 'Roboto', sans-serif";
      usage: "Primary UI font";
    }

    fontFamily ff_mono {
      stack: "'JetBrains Mono', 'Fira Code', monospace";
      usage: "Code, IDs, technical values";
    }

    typeScale ts_major_third {
      baseSize: 16;
      ratio: 1.25;
    }

    textStyle txt_display {
      role: display;
      font: ff_sans;
      size: 32;
      weight: 700;
      lineHeight: 1.2;
    }

    textStyle txt_h1 {
      role: h1;
      font: ff_sans;
      size: 28;
      weight: 700;
      lineHeight: 1.3;
    }

    textStyle txt_h2 {
      role: h2;
      font: ff_sans;
      size: 24;
      weight: 600;
      lineHeight: 1.3;
    }

    textStyle txt_h3 {
      role: h3;
      font: ff_sans;
      size: 20;
      weight: 600;
      lineHeight: 1.4;
    }

    textStyle txt_h4 {
      role: h4;
      font: ff_sans;
      size: 18;
      weight: 600;
      lineHeight: 1.4;
    }

    textStyle txt_body {
      role: body;
      font: ff_sans;
      size: 14;
      weight: 400;
      lineHeight: 1.5;
    }

    textStyle txt_body_strong {
      role: bodyStrong;
      font: ff_sans;
      size: 14;
      weight: 600;
      lineHeight: 1.5;
    }

    textStyle txt_caption {
      role: caption;
      font: ff_sans;
      size: 12;
      weight: 400;
      lineHeight: 1.4;
    }

    textStyle txt_label {
      role: label;
      font: ff_sans;
      size: 12;
      weight: 600;
      lineHeight: 1.4;
      letterSpacing: 0.5;
    }

    textStyle txt_code {
      role: code;
      font: ff_mono;
      size: 13;
      weight: 400;
      lineHeight: 1.6;
    }

    /* ------------- Breakpoints ----------------------------------- */

    breakpoint bp_sm {
      alias: "mobile";
      minWidth: 640;
    }

    breakpoint bp_md {
      alias: "tablet";
      minWidth: 768;
    }

    breakpoint bp_lg {
      alias: "desktop";
      minWidth: 1024;
    }

    breakpoint bp_xl {
      alias: "wide";
      minWidth: 1280;
    }

    breakpoint bp_2xl {
      alias: "ultrawide";
      minWidth: 1536;
    }

    /* ------------- Layout Patterns ------------------------------- */

    layoutPattern lp_sidebar {
      kind: sidebar;
      columns: 1;
      gap: sp_md;
      notes: "Collapsible sidebar with main content area";
    }

    layoutPattern lp_form {
      kind: formLayout;
      columns: 2;
      gap: sp_md;
      maxWidth: 960;
      notes: "Two-column form layout for entity forms";
    }

    layoutPattern lp_card_grid {
      kind: cardGrid;
      columns: 4;
      gap: sp_md;
      notes: "Dashboard KPI card grid";
    }

    layoutPattern lp_stack {
      kind: stack;
      gap: sp_lg;
      notes: "Vertical stack for list pages";
    }

    layoutPattern lp_split {
      kind: split;
      columns: 2;
      gap: sp_lg;
      notes: "Master-detail split view";
    }

    /* ------------- Density Profiles ------------------------------ */

    densityProfile dp_compact {
      level: compact;
      description: "Dense data tables and list views";
    }

    densityProfile dp_comfortable {
      level: comfortable;
      description: "Default form and detail views";
    }

    /* ------------- Fluid Sizes ----------------------------------- */

    fluidSize fs_page_title {
      role: h1;
      min: 22;
      max: 28;
      scale: "clamp(1.375rem, 2vw + 1rem, 1.75rem)";
      usage: "Responsive page title";
    }

    fluidSize fs_body {
      role: body;
      min: 13;
      max: 16;
      scale: "clamp(0.8125rem, 1vw + 0.5rem, 1rem)";
      usage: "Responsive body text";
    }

    /* ------------- Layout Constraints ---------------------------- */

    layoutConstraint lc_max_content {
      target: content;
      property: "max-width";
      value: "1440px";
      notes: "Maximum content width on ultra-wide screens";
    }

    layoutConstraint lc_sidebar_width {
      target: sidebar;
      property: "width";
      value: "260px";
      notes: "Default sidebar width";
    }

    layoutConstraint lc_sidebar_collapsed {
      target: sidebar;
      property: "width";
      value: "64px";
      breakpoint: bp_md;
      notes: "Collapsed sidebar on tablet";
    }

    /* ------------- Safe Areas ------------------------------------ */

    safeArea sa_web {
      platform: "web";
      top: false;
      bottom: false;
      left: false;
      right: false;
      notes: "No safe area insets for web";
    }

    /* ------------- Responsive Rules ------------------------------ */

    responsiveRule rr_sidebar_collapse {
      pattern: lp_sidebar;
      breakpoint: bp_md;
      transform: "Collapse sidebar to icon-only on tablet";
    }

    responsiveRule rr_form_single_col {
      pattern: lp_form;
      breakpoint: bp_sm;
      transform: "Stack form columns to single column on mobile";
    }

    responsiveRule rr_card_grid_stack {
      pattern: lp_card_grid;
      breakpoint: bp_sm;
      transform: "Stack KPI cards vertically on mobile";
    }

    /* ------------- Component Themes ------------------------------ */

    componentTheme ct_button_primary {
      target: button;
      variant: "primary";
      background: clr_primary;
      foreground: clr_surface;
      borderRadius: rad_sm;
      padding: sp_sm;
      textStyle: txt_body_strong;

      stateStyle hover {
        background: clr_primary_hover;
      }

      stateStyle active {
        background: clr_primary_active;
      }

      stateStyle disabled {
        background: clr_neutral;
      }
    }

    componentTheme ct_button_danger {
      target: button;
      variant: "danger";
      background: clr_danger;
      foreground: clr_surface;
      borderRadius: rad_sm;
      padding: sp_sm;
      textStyle: txt_body_strong;

      stateStyle hover {
        background: clr_danger_hover;
      }
    }

    componentTheme ct_card {
      target: card;
      background: clr_surface;
      borderRadius: rad_md;
      shadow: shd_sm;
      padding: sp_md;
    }

    componentTheme ct_badge_status {
      target: badge;
      borderRadius: rad_full;
      padding: sp_xs;
      textStyle: txt_caption;
    }

    componentTheme ct_nav_item {
      target: navItem;
      foreground: clr_text_secondary;
      padding: sp_sm;
      borderRadius: rad_sm;

      stateStyle hover {
        background: clr_primary_soft;
        foreground: clr_primary;
      }

      stateStyle active {
        background: clr_primary_soft;
        foreground: clr_primary;
      }
    }

    componentTheme ct_sidebar_item {
      target: sidebarItem;
      foreground: clr_text_secondary;
      padding: sp_sm;
      borderRadius: rad_sm;

      stateStyle hover {
        background: clr_primary_soft;
        foreground: clr_primary;
      }

      stateStyle active {
        background: clr_primary;
        foreground: clr_surface;
      }
    }

    componentTheme ct_input {
      target: input;
      background: clr_surface;
      foreground: clr_text_primary;
      borderRadius: rad_sm;
      padding: sp_sm;
      textStyle: txt_body;

      stateStyle focus {
        shadow: shd_sm;
      }

      stateStyle disabled {
        background: clr_background;
        foreground: clr_neutral;
      }
    }

    componentTheme ct_select {
      target: select;
      background: clr_surface;
      foreground: clr_text_primary;
      borderRadius: rad_sm;
      padding: sp_sm;
      textStyle: txt_body;
    }

    componentTheme ct_table {
      target: table;
      background: clr_surface;
      borderRadius: rad_md;
      shadow: shd_sm;
      padding: sp_sm;
      textStyle: txt_body;
    }

    componentTheme ct_stat_card {
      target: stat;
      background: clr_surface;
      borderRadius: rad_md;
      shadow: shd_sm;
      padding: sp_md;
      textStyle: txt_h3;
    }

    componentTheme ct_tag {
      target: tag;
      borderRadius: rad_full;
      padding: sp_xs;
      textStyle: txt_caption;
    }

    componentTheme ct_chip {
      target: chip;
      borderRadius: rad_full;
      padding: sp_xs;
      textStyle: txt_caption;
    }

    componentTheme ct_avatar {
      target: avatar;
      borderRadius: rad_full;
    }

  } /* end designSystem */

  /* =============================================================== */
  /*  SITE DEFINITION                                                 */
  /* =============================================================== */

  site eam_chi_site {

    meta {
      title: "CHI EAM";
      description: "Enterprise Asset Management System for CHI";
      brandTagline: "Composable Asset Intelligence";
      baseUrl: "/";
      favicon: "/favicon.ico";
      audience: "Maintenance planners, technicians, store managers, procurement officers, administrators";
    }

    designSystem: eam_ds;

    /* ------------- Business Goals -------------------------------- */

    bizGoal goal_uptime {
      statement: "Maximize asset uptime through proactive maintenance";
      metric: "OEE > 85%";
      priority: 1;
    }

    bizGoal goal_cost {
      statement: "Reduce maintenance and procurement costs through optimized workflows";
      metric: "PM compliance > 90%";
      priority: 2;
    }

    bizGoal goal_compliance {
      statement: "Ensure regulatory compliance with complete audit trails";
      metric: "100% work order traceability";
      priority: 3;
    }

    /* ------------- Navigation ------------------------------------ */

    navItem nav_dashboard {
      label: "Dashboard";
      view: ux.eam_chi.dashboard;
      kind: primary;
      icon: "mdi-view-dashboard";
    }

    navItem nav_assets {
      label: "Assets";
      view: ux.eam_chi.asset_management;
      kind: primary;
      icon: "mdi-cog-box";
    }

    navItem nav_maintenance {
      label: "Maintenance";
      view: ux.eam_chi.maintenance;
      kind: primary;
      icon: "mdi-wrench-clock";
    }

    navItem nav_work_orders {
      label: "Work Orders";
      view: ux.eam_chi.work_order;
      kind: primary;
      icon: "mdi-clipboard-text";
    }

    navItem nav_purchasing {
      label: "Purchasing";
      view: ux.eam_chi.purchasing;
      kind: primary;
      icon: "mdi-cart";
    }

    navItem nav_inventory {
      label: "Inventory";
      view: ux.eam_chi.inventory;
      kind: primary;
      icon: "mdi-warehouse";
    }

    navItem nav_admin {
      label: "Administration";
      view: ux.eam_chi.admin;
      kind: secondary;
      icon: "mdi-shield-account";
    }

    navItem nav_reports {
      label: "Reports";
      href: "/reports";
      kind: secondary;
      icon: "mdi-chart-bar";
    }

    navItem nav_help {
      label: "Help";
      href: "/help";
      kind: utility;
      icon: "mdi-help-circle";
    }

    navItem nav_profile {
      label: "My Profile";
      href: "/profile";
      kind: utility;
      icon: "mdi-account-circle";
    }

    /* ------------- App Layout ------------------------------------ */

    appLayout layout_main {
      kind: sidebar;
      routePrefix: "/";
      layoutPattern: eam_ds.lp_sidebar;

      region reg_sidebar {
        role: sidebar;
        navItems { nav_dashboard nav_assets nav_maintenance nav_work_orders nav_purchasing nav_inventory };
        notes: "Primary navigation sidebar with collapsible menu";
      }

      region reg_top {
        role: top;
        navItems { nav_reports nav_help nav_profile };
        notes: "Top header bar with search, notifications, user menu";
      }

      region reg_content {
        role: content;
        mountFeatures { ux.eam_chi.dashboard ux.eam_chi.asset_management ux.eam_chi.maintenance ux.eam_chi.work_order ux.eam_chi.purchasing ux.eam_chi.inventory ux.eam_chi.admin };
        notes: "Main content area where feature views are rendered";
      }

      region reg_footer {
        role: footer;
        notes: "Footer with copyright and version info";
      }
    }

    appLayout layout_auth {
      kind: blank;
      routePrefix: "/auth";

      region reg_auth_content {
        role: content;
        notes: "Full-screen authentication pages (login, forgot password)";
      }
    }

    /* ============================================================= */
    /*  FORMS                                                         */
    /* ============================================================= */

    /* ------------- Asset Forms ----------------------------------- */

    form form_asset {
      title: "Asset";
      description: "Create or edit an asset record";
      layoutPattern: eam_ds.lp_form;
      bind-view: ux.eam_chi.asset_form_view;

      fields {
        field asset_code {
          label: "Asset Code";
          type: text;
          required: true;
          placeholder: "Enter asset code";
        }
        field description {
          label: "Description";
          type: textarea;
          required: true;
        }
        field serial_number {
          label: "Serial Number";
          type: text;
        }
        field asset_class_id {
          label: "Asset Class";
          type: select;
          required: true;
        }
        field location_id {
          label: "Location";
          type: select;
          required: true;
        }
        field system_id {
          label: "System";
          type: select;
        }
        field manufacturer_id {
          label: "Manufacturer";
          type: select;
        }
        field model_id {
          label: "Model";
          type: select;
        }
        field purchase_date {
          label: "Purchase Date";
          type: date;
        }
        field purchase_cost {
          label: "Purchase Cost";
          type: number;
        }
        field warranty_expiry {
          label: "Warranty Expiry";
          type: date;
        }
        field criticality {
          label: "Criticality";
          type: select;
          required: true;
          options { "Critical" "High" "Medium" "Low" };
        }
        field status {
          label: "Status";
          type: select;
          required: true;
          options { "Active" "Inactive" "Disposed" "In Storage" };
        }
      }

      submission: int_submit_asset;
    }

    form form_location {
      title: "Location";
      description: "Create or edit a location";
      layoutPattern: eam_ds.lp_form;

      fields {
        field code {
          label: "Location Code";
          type: text;
          required: true;
        }
        field description {
          label: "Description";
          type: textarea;
          required: true;
        }
        field location_type_id {
          label: "Location Type";
          type: select;
          required: true;
        }
        field site_id {
          label: "Site";
          type: select;
          required: true;
        }
        field parent_location_id {
          label: "Parent Location";
          type: select;
        }
      }

      submission: int_submit_entity;
    }

    /* ------------- Maintenance Forms ----------------------------- */

    form form_maintenance_request {
      title: "Maintenance Request";
      description: "Submit a new maintenance request";
      layoutPattern: eam_ds.lp_form;
      bind-view: ux.eam_chi.maintenance_request_form_view;

      fields {
        field request_number {
          label: "Request Number";
          type: text;
          required: true;
          helpText: "Auto-generated if left blank";
        }
        field description {
          label: "Description";
          type: textarea;
          required: true;
          placeholder: "Describe the issue or request";
        }
        field asset_id {
          label: "Asset";
          type: select;
          required: true;
        }
        field priority {
          label: "Priority";
          type: select;
          required: true;
          options { "Emergency" "Urgent" "High" "Normal" "Low" };
        }
        field category {
          label: "Category";
          type: select;
          options { "Corrective" "Predictive" "Emergency" "Improvement" };
        }
        field requested_date {
          label: "Requested Date";
          type: date;
          required: true;
        }
        field reported_by {
          label: "Reported By";
          type: select;
        }
      }

      submission: int_submit_maintenance_request;
    }

    form form_maintenance_plan {
      title: "Maintenance Plan";
      description: "Create or edit a preventive maintenance plan";
      layoutPattern: eam_ds.lp_form;

      fields {
        field plan_number {
          label: "Plan Number";
          type: text;
          required: true;
        }
        field description {
          label: "Description";
          type: textarea;
          required: true;
        }
        field asset_id {
          label: "Asset";
          type: select;
          required: true;
        }
        field maintenance_type {
          label: "Maintenance Type";
          type: select;
          required: true;
          options { "Preventive" "Predictive" "Condition-Based" };
        }
        field schedule_type {
          label: "Schedule Type";
          type: select;
          required: true;
          options { "Calendar" "Meter" "Condition" };
        }
        field interval_value {
          label: "Interval Value";
          type: number;
        }
        field interval_unit {
          label: "Interval Unit";
          type: select;
          options { "Days" "Weeks" "Months" "Years" "Hours" "Kilometers" };
        }
        field is_active {
          label: "Active";
          type: switch;
        }
      }

      submission: int_submit_entity;
    }

    /* ------------- Work Order Forms ------------------------------ */

    form form_work_order {
      title: "Work Order";
      description: "Create or edit a work order";
      layoutPattern: eam_ds.lp_form;
      bind-view: ux.eam_chi.work_order_form_view;

      fields {
        field wo_number {
          label: "WO Number";
          type: text;
          required: true;
        }
        field description {
          label: "Description";
          type: textarea;
          required: true;
        }
        field wo_type {
          label: "Type";
          type: select;
          required: true;
          options { "Corrective" "Preventive" "Predictive" "Emergency" "Inspection" "Project" };
        }
        field priority {
          label: "Priority";
          type: select;
          required: true;
          options { "Emergency" "Urgent" "High" "Normal" "Low" };
        }
        field asset_id {
          label: "Asset";
          type: select;
          required: true;
        }
        field location_id {
          label: "Location";
          type: select;
        }
        field assigned_to {
          label: "Assigned To";
          type: select;
        }
        field planned_start {
          label: "Planned Start";
          type: datetime;
          required: true;
        }
        field planned_end {
          label: "Planned End";
          type: datetime;
          required: true;
        }
        field job_plan_id {
          label: "Job Plan";
          type: select;
          helpText: "Select a pre-defined job plan to auto-populate tasks";
        }
        field estimated_hours {
          label: "Estimated Hours";
          type: number;
        }
        field estimated_cost {
          label: "Estimated Cost";
          type: number;
        }
      }

      submission: int_submit_work_order;
    }

    form form_safety_permit {
      title: "Safety Permit";
      description: "Create a safety permit for work execution";
      layoutPattern: eam_ds.lp_form;

      fields {
        field permit_number {
          label: "Permit Number";
          type: text;
          required: true;
        }
        field permit_type {
          label: "Permit Type";
          type: select;
          required: true;
          options { "Hot Work" "Confined Space" "Electrical" "Working at Height" "Excavation" "General" };
        }
        field work_order_id {
          label: "Work Order";
          type: select;
          required: true;
        }
        field description {
          label: "Description";
          type: textarea;
          required: true;
        }
        field valid_from {
          label: "Valid From";
          type: datetime;
          required: true;
        }
        field valid_to {
          label: "Valid To";
          type: datetime;
          required: true;
