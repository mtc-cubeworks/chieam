          }
          item stat_alerts {
            label: "Active Alerts";
            value: "dynamic";
            icon: "mdi-alert-circle";
          }
          item stat_readings_today {
            label: "Readings Today";
            value: "dynamic";
            icon: "mdi-chart-line";
          }
