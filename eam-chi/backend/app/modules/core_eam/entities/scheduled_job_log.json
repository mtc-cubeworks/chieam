{
  "name": "scheduled_job_log",
  "label": "Scheduled Job Log",
  "module": "Enterprise",
  "table_name": "scheduled_job_log",
  "title_field": "job_name",
  "in_sidebar": 0,
  "naming": "SJL-{#####}",
  "icon": "clock",
  "group": "System Configuration",
  "search": true,
  "fields": [
    {
      "name": "job_id",
      "label": "Job ID",
      "field_type": "string",
      "required": true,
      "in_list_view": true
    },
    {
      "name": "job_name",
      "label": "Job Name",
      "field_type": "string",
      "required": true,
      "in_list_view": true
    },
    {
      "name": "status",
      "label": "Status",
      "field_type": "string",
      "required": true,
      "in_list_view": true,
      "options": ["Success", "Error", "Running", "Skipped"]
    },
    {
      "name": "started_at",
      "label": "Started At",
      "field_type": "datetime",
      "required": true,
      "in_list_view": true
    },
    {
      "name": "completed_at",
      "label": "Completed At",
      "field_type": "datetime",
      "in_list_view": true
    },
    {
      "name": "duration_seconds",
      "label": "Duration (s)",
      "field_type": "float"
    },
    {
      "name": "records_created",
      "label": "Records Created",
      "field_type": "int"
    },
    {
      "name": "records_updated",
      "label": "Records Updated",
      "field_type": "int"
    },
    {
      "name": "error_message",
      "label": "Error Message",
      "field_type": "text",
      "display_depends_on": "eval:doc.status=='Error'"
    },
    {
      "name": "error_traceback",
      "label": "Error Traceback",
      "field_type": "text",
      "display_depends_on": "eval:doc.status=='Error'"
    },
    {
      "name": "details",
      "label": "Details",
      "field_type": "text"
    },
    {
      "name": "trigger_type",
      "label": "Trigger Type",
      "field_type": "string",
      "options": ["Cron", "Manual", "Event"]
    },
    {
      "name": "cron_expression",
      "label": "Cron Expression",
      "field_type": "string"
    }
  ],
  "rbac": {
    "SystemManager": ["*"]
  }
}
