{
  "name": "item_issue",
  "label": "Item Issue",
  "module": "Procurement",
  "table_name": "item_issue",
  "title_field": "id",
  "in_sidebar": 1,
  "naming": "PI-{#####}",
  "icon": "log-out",
  "group": "Inventory Operations",
  "search": true,
  "workflow": {
    "enabled": true,
    "state_field": "workflow_state",
    "initial_state": "Requested",
    "states": [
      "Requested",
      "Issued",
      "Closed"
    ],
    "transitions": [
      {
        "from": "Requested",
        "to": "Issued",
        "action": "Issue_Item",
        "label": "Issue Item"
      },
      {
        "from": "Issued",
        "to": "Closed",
        "action": "Complete",
        "label": "Complete"
      }
    ]
  },
  "fields": [
    {
      "name": "workflow_state",
      "label": "Workflow State",
      "field_type": "string",
      "hidden": true
    },
    {
      "name": "issue_type",
      "label": "Issue Type",
      "field_type": "select",
      "options": [
        "Emergency Issue",
        "Consumption",
        "Transfer",
        "WO Parts Issue",
        "WO Equipment Issue",
        "Loner"
      ],
      "required": false,
      "in_list_view": true
    },
    {
      "name": "issue_to",
      "label": "Issue To",
      "field_type": "link",
      "link_entity": "employee",
      "required": false,
      "in_list_view": true
    },
    {
      "name": "date_issued",
      "label": "Date Issued",
      "field_type": "datetime",
      "required": false,
      "in_list_view": true
    },
    {
      "name": "work_order_activity",
      "label": "Work Order Activity",
      "field_type": "link",
      "link_entity": "work_order_activity",
      "in_list_view": true
    },
    {
      "name": "site",
      "label": "Site",
      "field_type": "link",
      "link_entity": "site",
      "required": false,
      "fetch_from": "work_order_activity.site"
    },
    {
      "name": "department",
      "label": "Department",
      "field_type": "link",
      "link_entity": "department",
      "required": false,
      "fetch_from": "work_order_activity.department"
    },
    {
      "name": "cost_code",
      "label": "Cost Code",
      "field_type": "link",
      "link_entity": "cost_code",
      "required": false
    },
    {
      "name": "work_order",
      "label": "Work Order",
      "field_type": "link",
      "link_entity": "work_order"
    },
    {
      "name": "issue_destination",
      "label": "Issue Destination",
      "field_type": "select",
      "options": ["Direct to Job", "Storeroom", "Department"]
    },
    {
      "name": "require_wo",
      "label": "Require Work Order",
      "field_type": "boolean"
    }
  ],
  "rbac": {
    "SystemManager": [
      "*"
    ]
  },
  "children": [
    {
      "entity": "item_issue_line",
      "fk_field": "item_issue",
      "label": "Lines"
    }
  ],
  "links": []
}