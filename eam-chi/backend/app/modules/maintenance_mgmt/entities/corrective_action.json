    {"name": "due_date", "label": "Due Date", "field_type": "date", "in_list_view": true},
    {"name": "completion_date", "label": "Completion Date", "field_type": "date"},
    {"name": "verification_date", "label": "Verification Date", "field_type": "date"},
    {"name": "verified_by", "label": "Verified By", "field_type": "link", "link_entity": "employee"},
