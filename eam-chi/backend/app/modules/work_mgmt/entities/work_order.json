{
  "name": "work_order",
  "label": "Work Order",
  "module": "Work Management",
  "table_name": "work_order",
  "title_field": "description",
  "in_sidebar": 1,
  "naming": "WO-{#####}",
  "icon": "clipboard",
  "group": "Work Orders",
  "search": true,
  "workflow": {
    "enabled": true,
    "state_field": "workflow_state",
    "initial_state": "Requested",
    "states": [
      "Requested",
      "Approved",
      "In Progress",
      "Closed"
    ],
    "transitions": [
      {
        "from": "Requested",
        "to": "Approved",
        "action": "Approve",
        "label": "Approve"
      },
      {
        "from": "Approved",
        "to": "In Progress",
        "action": "Start",
        "label": "Start"
      },
      {
        "from": "In Progress",
        "to": "Closed",
        "action": "Complete",
        "label": "Complete"
      },
      {
        "from": "Closed",
        "to": "In Progress",
        "action": "Reopen",
        "label": "Reopen"
      }
    ]
  },
  "fields": [
    {
      "name": "workflow_state",
      "label": "Workflow State",
      "field_type": "string",
      "hidden": true
    },
    {
      "name": "work_order_type",
      "label": "Type",
      "field_type": "select",
      "options": [
        "Preventive Maintenance",
        "Corrective Maintenance"
      ],
      "required": false,
      "in_list_view": true
    },
    {
      "name": "description",
      "label": "Description",
      "field_type": "text",
      "required": false,
      "in_list_view": true
    },
    {
      "name": "category_of_failure",
      "label": "Category of Failure",
      "field_type": "link",
      "link_entity": "category_of_failure"
    },
    {
      "name": "due_date",
      "label": "Due Date",
      "field_type": "date",
      "required": false,
      "in_list_view": true
    },
    {
      "name": "priority",
      "label": "Priority",
      "field_type": "select",
      "options": [
        "Low",
        "Medium",
        "High",
        "Emergency"
      ],
      "in_list_view": true
    },
    {
      "name": "severity",
      "label": "Severity",
      "field_type": "select",
      "options": [
        "Low",
        "Medium",
        "High"
      ]
    },
    {
      "name": "incident",
      "label": "Incident",
      "field_type": "link",
      "link_entity": "incident"
    },
    {
      "name": "site",
      "label": "Site",
      "field_type": "link",
      "link_entity": "site",
      "required": false
    },
    {
      "name": "department",
      "label": "Department",
      "field_type": "link",
      "link_entity": "department",
      "required": false
    },
    {
      "name": "cost_code",
      "label": "Cost Code",
      "field_type": "link",
      "link_entity": "cost_code",
      "required": false
    },
    {
      "name": "job_plan",
      "label": "Job Plan",
      "field_type": "link",
      "link_entity": "job_plan"
    },
    {
      "name": "scheduled_start",
      "label": "Scheduled Start",
      "field_type": "datetime"
    },
    {
      "name": "scheduled_end",
      "label": "Scheduled End",
      "field_type": "datetime"
    },
    {
      "name": "actual_start",
      "label": "Actual Start",
      "field_type": "datetime",
      "readonly": true
    },
    {
      "name": "actual_end",
      "label": "Actual End",
      "field_type": "datetime",
      "readonly": true
    },
    {
      "name": "estimated_cost",
      "label": "Estimated Cost",
      "field_type": "float"
    },
    {
      "name": "approval_level",
      "label": "Approval Level",
      "field_type": "string",
      "readonly": true
    },
    {
      "name": "approved_by",
      "label": "Approved By",
      "field_type": "link",
      "link_entity": "employee",
      "readonly": true
    },
    {
      "name": "total_labor_cost",
      "label": "Total Labor Cost",
      "field_type": "float",
      "readonly": true
    },
    {
      "name": "total_equipment_cost",
      "label": "Total Equipment Cost",
      "field_type": "float",
      "readonly": true
    },
    {
      "name": "total_parts_cost",
      "label": "Total Parts Cost",
      "field_type": "float",
      "readonly": true
    },
    {
      "name": "total_cost",
      "label": "Total Cost",
      "field_type": "float",
      "readonly": true,
      "in_list_view": true
    },
    {
      "name": "safety_permit",
      "label": "Safety Permit",
      "field_type": "link",
      "link_entity": "safety_permit"
    },
    {
      "name": "loto_required",
      "label": "LOTO Required",
      "field_type": "boolean",
      "default": false
    },
    {
      "name": "downtime_start",
      "label": "Downtime Start",
      "field_type": "datetime",
      "readonly": true
    },
    {
      "name": "downtime_end",
      "label": "Downtime End",
      "field_type": "datetime",
      "readonly": true
    },
    {
      "name": "downtime_hours",
      "label": "Downtime Hours",
      "field_type": "float",
      "readonly": true
    },
    {
      "name": "cause_code",
      "label": "Cause Code",
      "field_type": "string"
    },
    {
      "name": "remedy_code",
      "label": "Remedy Code",
      "field_type": "string"
    },
    {
      "name": "failure_notes",
      "label": "Failure Notes",
      "field_type": "text"
    },
    {
      "name": "technician_findings",
      "label": "Technician Findings",
      "field_type": "text"
    },
    {
      "name": "work_performed",
      "label": "Work Performed",
      "field_type": "text"
    },
    {
      "name": "recommendations",
      "label": "Recommendations",
      "field_type": "text"
    },
    {
      "name": "follow_up_work_order",
      "label": "Follow-up Work Order",
      "field_type": "link",
      "link_entity": "work_order"
    },
    {
      "name": "parent_work_order",
      "label": "Parent Work Order",
      "field_type": "link",
      "link_entity": "work_order"
    }
  ],
  "rbac": {
    "SystemManager": [
      "*"
    ]
  },
  "links": [
    {
      "entity": "work_order_activity",
      "fk_field": "work_order",
      "label": "Activities"
    },
    {
      "entity": "safety_permit",
      "fk_field": "work_order",
      "label": "Safety Permits"
    },
    {
      "entity": "tool_checkout",
      "fk_field": "work_order",
      "label": "Tool Checkouts"
    }
  ],
  "form_state": {
    "editable_when": {
      "workflow_state": [
        "requested"
      ]
    }
  }
}
