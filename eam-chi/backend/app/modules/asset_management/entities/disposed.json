{
  "name": "disposed",
  "label": "Disposed",
  "module": "Asset Management",
  "table_name": "disposed",
  "title_field": "id",
  "in_sidebar": 1,
  "naming": "DSP-{####}",
  "icon": "trash-2",
  "group": "Assets",
  "actions": [
    {
      "action": "create_purchase_request",
      "label": "Create Purchase Request",
      "method": "app.modules.asset_management.apis.disposed.create_purchase_request_on_dispose",
      "confirm": "Create a Purchase Request for replacement of this disposed asset?",
