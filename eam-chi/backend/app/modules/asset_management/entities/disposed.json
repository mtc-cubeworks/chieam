        "disposal_status": [
          "Approved"
        ]
      }
    }
  ],
  "fields": [
    {
      "name": "asset",
      "label": "Asset",
      "field_type": "link",
      "link_entity": "asset",
      "required": false,
      "in_list_view": true
    },
    {
      "name": "condition",
      "label": "Condition",
      "field_type": "select",
      "options": [
        {
          "label": "Damage",
          "value": "Damage"
        },
        {
          "label": "Non Operational",
          "value": "Non Operational"
        },
        {
          "label": "Missing Parts",
          "value": "Missing Parts"
        }
      ]
    },
    {
      "name": "disposal_date",
      "label": "Disposal Date",
      "field_type": "date",
      "required": false,
      "in_list_view": true
    },
    {
      "name": "disposal_reason",
      "label": "Disposal Reason",
      "field_type": "text",
      "required": false
    },
    {
      "name": "disposal_method",
      "label": "Disposal Method",
      "field_type": "select",
      "options": [
        {
          "label": "Scrap",
          "value": "Scrap"
        },
        {
          "label": "Sale",
          "value": "Sale"
        },
        {
          "label": "Donation",
          "value": "Donation"
        }
      ],
      "required": false
    },
    {
      "name": "disposal_status",
      "label": "Disposal Status",
      "field_type": "select",
      "options": [
        {
          "label": "Draft",
          "value": "Draft"
        },
        {
          "label": "Submitted",
          "value": "Submitted"
        },
        {
          "label": "Approved",
          "value": "Approved"
        },
        {
          "label": "Reverse",
          "value": "Reverse"
        }
      ]
    },
    {
      "name": "site",
      "label": "Site",
      "field_type": "link",
      "link_entity": "site",
      "required": false,
      "in_list_view": true
    }
  ],
  "rbac": {
    "SystemManager": [
      "*"
    ]
  }
