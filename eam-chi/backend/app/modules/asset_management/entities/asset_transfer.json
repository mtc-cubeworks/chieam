      {"from": "Draft", "to": "Pending Approval", "action": "Submit", "label": "Submit for Approval"},
      {"from": "Pending Approval", "to": "Approved", "action": "Approve", "label": "Approve"},
      {"from": "Pending Approval", "to": "Cancelled", "action": "Cancel", "label": "Cancel"},
      {"from": "Approved", "to": "In Transit", "action": "Ship", "label": "Mark In Transit"},
      {"from": "In Transit", "to": "Received", "action": "Receive", "label": "Confirm Receipt"}
    ]
  },
  "fields": [
