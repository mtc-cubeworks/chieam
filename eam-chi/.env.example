# ============================================================
# EAM System — Environment Variables
# ============================================================
# Copy to backend/.env (the backend reads .env from its own directory).
# Only DATABASE_URL is required; everything else has sensible defaults.

# ── Database (required) ──────────────────────────────────────
# Async driver (used by the app):
DATABASE_URL=postgresql+asyncpg://eam_user:eam_password@localhost:5432/eam_db
# Sync driver (used by Alembic migrations — auto-derived if omitted):
# DATABASE_URL_SYNC=postgresql://eam_user:eam_password@localhost:5432/eam_db

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ─────────────────────────────────────────────────
# Set this in the shell or in frontend/.env
# NUXT_PUBLIC_API_URL=http://localhost:8010/api

# ── CORS ─────────────────────────────────────────────────────
# JSON array of allowed origins (defaults cover localhost:3000-3002)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# SOCKETIO_CORS_ORIGINS=["http://localhost:3000"]

# ── Email / SMTP (optional) ─────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM_ADDRESS=your-email@gmail.com
# EMAIL_FROM_NAME=EAM Notifications
# EMAIL_ENABLED=false

# ── File Uploads ─────────────────────────────────────────────
# UPLOAD_DIR=uploads
# MAX_UPLOAD_SIZE_MB=10

# ── Seeds (development only) ────────────────────────────────
# RUN_SEEDS=false

# Final local credentials
# Database
# Host: localhost
# Port: 5432
# Database: eam_app_local_db
# User: eam_app_local
# Password: eam_app_local_password
# App admin
# Username: admin
# Password: admin123
